---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import TableCard from '../components/TableCard.astro';
import TrustBanner from '../components/TrustBanner.astro';
import CommunityCallout from '../components/CommunityCallout.astro';
import Icon from '../components/Icon.astro';
import { url, SITE } from '../utils/url';

const REPO = 'https://github.com/thereisnotime/tint-cheats';
const REQUEST_CHEAT = `${REPO}/issues/new?template=request-cheat.yml`;

const tables = (await getCollection('tables')).sort(
  (a, b) => b.data.updated.valueOf() - a.data.updated.valueOf()
);

// Unique, sorted tag cloud.
const tagCounts = new Map<string, number>();
for (const entry of tables) {
  for (const tag of entry.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));

const title = 'Cheat Engine Tables & Trainers — Free & Open Source | tint-cheats';
const description =
  'Free, open-source Cheat Engine tables and trainers for single-player games. Every table is version-controlled, checksum-verified, and VirusTotal-scanned. No paywalls, no shady downloads.';
const canonical = new URL(url('/'), SITE).href;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Cheat Engine Tables & Trainers',
    description,
    url: canonical,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: tables.map((entry, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: entry.data.title,
      url: new URL(url('/tables/' + entry.id), SITE).href,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Are these Cheat Engine tables safe?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Every table is open source, hosted on GitHub, checksum-verified, and scanned with VirusTotal. You can read the source before running it. We never bundle installers, loaders, or ad-gated downloads.',
        },
      },
      {
        '@type': 'Question',
        name: 'Are the tables free?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. Everything here is completely free and open source. There are no paywalls, surveys, or premium tiers.',
        },
      },
      {
        '@type': 'Question',
        name: 'Do the tables work in online or multiplayer games?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. These tables are intended for single-player and offline use only. Using them in online or multiplayer games can break the game, ruin it for others, and get your account banned.',
        },
      },
    ],
  },
];
---

<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="hero">
    <h1 class="hero__title">TINT Cheats</h1>
    <p class="hero__lead">
      Free, open-source Cheat Engine tables and trainers for single-player games.
      Verified, checksummed, no gates.
    </p>
    <TrustBanner />
  </section>

  <CommunityCallout
    heading="Join the TINT Cheats community"
    blurb="Get notified about new tables and updates, request cheats, report breakage, and chat with other players. Free, no spam, leave anytime."
  />

  <section id="tables" class="section" aria-labelledby="tables-heading">
    {tables.length > 0 && (
      <form class="searchbar" role="search" id="search-form" autocomplete="off">
        <Icon name="search" class="searchbar__icon" size={20} />
        <input
          type="search"
          id="table-search"
          class="searchbar__input"
          name="q"
          placeholder="Search games, tags, or cheats…"
          aria-label="Search tables"
        />
        <button type="button" class="searchbar__clear" id="search-clear" aria-label="Clear search" hidden>
          <span aria-hidden="true">×</span>
        </button>
      </form>
    )}

    <div class="section__bar">
      <h2 id="tables-heading" class="section__title section__title--bare">
        Tables <span class="section__count" id="table-count">{tables.length}</span>
      </h2>
    </div>

    {tables.length === 0 ? (
      <p class="empty-state">
        No tables published yet. Want to contribute one?
        <a href={REQUEST_CHEAT} rel="noopener">Request a cheat on GitHub</a>.
      </p>
    ) : (
      <>
        <ul class="grid table-grid" role="list" id="table-list">
          {tables.map((entry) => (
            <li
              class="table-grid__item"
              data-search={[
                entry.data.title,
                entry.data.game,
                entry.data.tags.join(' '),
                entry.data.cheats.map((c) => c.name).join(' '),
                entry.data.description,
              ].join(' ').toLowerCase()}
            >
              <TableCard entry={entry} />
            </li>
          ))}
        </ul>
        <p class="search__empty" id="search-empty" hidden>
          No tables match your search.
          <a href={REQUEST_CHEAT} rel="noopener">Request this one</a>.
        </p>
      </>
    )}
  </section>

  {tags.length > 0 && (
    <section class="section" aria-labelledby="tags-heading">
      <h2 id="tags-heading" class="section__title">Browse by tag</h2>
      <ul class="tag-cloud" role="list">
        {tags.map(([tag, count]) => (
          <li>
            <a class="tag" href={url('/tags/' + tag)}>{tag} <span class="tag__count">{count}</span></a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="section" aria-labelledby="trust-heading">
    <h2 id="trust-heading" class="section__title">How it works</h2>
    <ul class="trust-list">
      <li><Icon name="search" class="trust-list__icon" size={22} /><div><strong>Verifiable.</strong> Tables live in a public GitHub repo. Inspect the diff and the source before you run anything.</div></li>
      <li><Icon name="lock" class="trust-list__icon" size={22} /><div><strong>Checksums.</strong> Every downloadable file ships with a published SHA-256 so you can confirm you got exactly what we built.</div></li>
      <li><Icon name="shield" class="trust-list__icon" size={22} /><div><strong>VirusTotal.</strong> Files are scanned and the scan link is included on each table page.</div></li>
      <li><Icon name="gamepad" class="trust-list__icon" size={22} /><div><strong>Single-player only.</strong> These are for offline play. We do not support online or competitive cheating.</div></li>
    </ul>
  </section>

  <section class="star-cta" aria-labelledby="star-heading">
    <div class="star-cta__body">
      <h2 id="star-heading" class="star-cta__title">Did a table save you some grinding?</h2>
      <p class="star-cta__lead">
        Stars keep this project visible above the survey-gate scam sites and help
        more people find tables they can actually trust. It is free and takes a second.
      </p>
    </div>
    <a class="btn btn--star" href={REPO} rel="noopener">
      <Icon name="star" size={18} /> Star on GitHub
    </a>
  </section>
</Base>

<script>
  const form = document.getElementById('search-form');
  const input = document.getElementById('table-search') as HTMLInputElement | null;
  const list = document.getElementById('table-list');
  const emptyMsg = document.getElementById('search-empty');
  const clearBtn = document.getElementById('search-clear');
  const count = document.getElementById('table-count');

  if (input && list) {
    const items = Array.from(list.querySelectorAll<HTMLElement>('.table-grid__item'));
    const total = items.length;

    const apply = () => {
      const q = input.value.trim().toLowerCase();
      let visible = 0;
      for (const item of items) {
        const hay = item.dataset.search ?? '';
        const match = q === '' || hay.includes(q);
        item.hidden = !match;
        if (match) visible++;
      }
      if (emptyMsg) emptyMsg.hidden = visible !== 0;
      if (count) count.textContent = q === '' ? String(total) : `${visible}/${total}`;
      if (clearBtn) clearBtn.hidden = q === '';
    };

    // Prefill from ?q= so the header search (on any page) can drive this.
    const q = new URLSearchParams(window.location.search).get('q');
    if (q) input.value = q;

    input.addEventListener('input', apply);
    form?.addEventListener('submit', (e) => e.preventDefault());
    clearBtn?.addEventListener('click', () => {
      input.value = '';
      input.focus();
      apply();
    });
    apply();
  }
</script>
