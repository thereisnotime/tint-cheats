---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import TableLayout from '../../layouts/TableLayout.astro';
import { url, SITE } from '../../utils/url';

export const getStaticPaths = (async () => {
  const tables = await getCollection('tables');
  return tables.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);

const pageUrl = new URL(url('/tables/' + entry.id), SITE).href;
const { data } = entry;

const abs = (src?: string) => (src ? new URL(src, SITE).href : undefined);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'VideoGame',
    name: data.game,
    ...(data.game_description && { description: data.game_description }),
    ...(data.game_logo && { image: abs(data.game_logo.src) }),
    ...(data.trailer && {
      trailer: { '@type': 'VideoObject', name: `${data.game} trailer`, url: data.trailer },
    }),
    ...(data.screenshots.length > 0 && {
      screenshot: data.screenshots.map((s) => abs(s.src)),
    }),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: data.title,
    applicationCategory: 'GameApplication',
    operatingSystem: data.platforms.join(', '),
    softwareVersion: data.table_version,
    description: data.description,
    url: pageUrl,
    ...(data.author && {
      author: {
        '@type': 'Person',
        name: data.author,
        ...(data.author_url && { url: data.author_url }),
      },
    }),
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: new URL(url('/'), SITE).href,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Tables',
        item: new URL(url('/#tables'), SITE).href,
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: data.game,
        item: pageUrl,
      },
    ],
  },
];
---

<TableLayout entry={entry} jsonLd={jsonLd}>
  <Content />
</TableLayout>
