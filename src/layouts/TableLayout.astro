---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import TrustBanner from '../components/TrustBanner.astro';
import Disclaimer from '../components/Disclaimer.astro';
import StatusBadge from '../components/StatusBadge.astro';
import CompatibilityMatrix from '../components/CompatibilityMatrix.astro';
import ChecksumBox from '../components/ChecksumBox.astro';
import FeatureList from '../components/FeatureList.astro';
import CommunityCallout from '../components/CommunityCallout.astro';
import Icon from '../components/Icon.astro';
import { url } from '../utils/url';

interface Props {
  entry: CollectionEntry<'tables'>;
  jsonLd?: object | object[];
}

const { entry, jsonLd }: Props = Astro.props;
const data = entry.data;

const dateFmt = new Intl.DateTimeFormat('en', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const updatedLabel = dateFmt.format(data.updated);
const updatedIso = data.updated.toISOString();

// OG image: pass the resolved cover src when present, else let Base default.
const ogImage = data.cover?.src;
---

<Base
  title={data.title}
  description={data.description}
  image={ogImage}
  type="article"
  jsonLd={jsonLd}
>
  <TrustBanner />

  <header class="table-head">
    {
      data.game_logo && (
        <Image
          class="table-head__logo"
          src={data.game_logo}
          alt={`${data.game} logo`}
          height={72}
          loading="eager"
        />
      )
    }
    <h1>{data.title}</h1>
    <div class="table-head__meta">
      <StatusBadge status={data.status} />
      <span class="meta-item">
        <span class="sr-only">Game</span>
        {data.game}
      </span>
      <span class="meta-item">
        <dt>Table</dt><dd>v{data.table_version}</dd>
      </span>
      {
        data.author && (
          <span class="meta-item">
            <dt>By</dt>
            <dd>
              {data.author_url ? (
                <a href={data.author_url} rel="noopener author">{data.author}</a>
              ) : (
                data.author
              )}
            </dd>
          </span>
        )
      }
      <span class="meta-item">
        <dt>Cheat Engine</dt><dd>{data.ce_version}</dd>
      </span>
      <span class="meta-item">
        <dt>Platforms</dt><dd>{data.platforms.join(', ')}</dd>
      </span>
      <span class="meta-item">
        <dt>Updated</dt>
        <dd><time datetime={updatedIso}>{updatedLabel}</time></dd>
      </span>
    </div>

    {
      data.tags.length > 0 && (
        <div class="table-head__tags">
          {data.tags.map((tag) => (
            <a class="tag" href={url('/tags/' + tag)}>
              #{tag}
            </a>
          ))}
        </div>
      )
    }

    {
      data.game_description && <p class="table-head__desc">{data.game_description}</p>
    }

    <div class="table-head__actions">
      {
        data.files.length > 0 && (
          <a
            class="btn btn--primary"
            href={url(`/downloads/${entry.id}/${data.files[0].name}`)}
            download={data.files[0].name}
            type="application/octet-stream"
          >
            <Icon name="download" size={18} /> Download table
          </a>
        )
      }
      {
        data.trailer && (
          <a class="btn btn--ghost" href={data.trailer} target="_blank" rel="noopener">
            <Icon name="play" size={18} /> Watch trailer
          </a>
        )
      }
      <a class="btn btn--ghost" href={url('/how-to-use-cheat-engine')}>
        <Icon name="search" size={18} /> How to use
      </a>
    </div>

    {
      data.cover && (
        <div class="table-head__cover">
          <Image
            class="table-head__cover-bg"
            src={data.cover}
            alt=""
            aria-hidden="true"
            widths={[400, 800]}
            sizes="100vw"
            loading="eager"
          />
          <Image
            class="table-head__cover-img"
            src={data.cover}
            alt={`${data.title} cover`}
            widths={[400, 800, 1200]}
            sizes="(max-width: 64rem) 100vw, 64rem"
            loading="eager"
          />
        </div>
      )
    }
  </header>

  {
    data.cheats.length > 0 && (
      <section class="section" aria-labelledby="cheats-title">
        <h2 id="cheats-title" class="section__title">
          Cheats <span class="section__count">{data.cheats.length}</span>
        </h2>
        <FeatureList cheats={data.cheats} />
      </section>
    )
  }

  {
    data.screenshots.length > 0 && (
      <section class="section" aria-labelledby="shots-title">
        <h2 id="shots-title" class="section__title">
          Screenshots <span class="section__count">{data.screenshots.length}</span>
        </h2>
        <ul class="gallery" role="list">
          {data.screenshots.map((shot, i) => (
            <li>
              <a class="gallery__item" href={shot.src} target="_blank" rel="noopener">
                <Image
                  src={shot}
                  alt={`${data.game} screenshot ${i + 1}`}
                  widths={[400, 800]}
                  sizes="(max-width: 48rem) 100vw, 24rem"
                  loading="lazy"
                />
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="section" aria-labelledby="compat-title">
    <h2 id="compat-title" class="section__title">Compatibility</h2>
    <CompatibilityMatrix gameVersions={data.game_versions} />
  </section>

  <section class="section" aria-labelledby="dl-title">
    <h2 id="dl-title" class="section__title">Downloads</h2>
    <ChecksumBox
      files={data.files}
      folder={entry.id}
      virustotal={data.virustotal}
    />
  </section>

  <CommunityCallout
    blurb={`Get notified when the ${data.game} table updates, request new cheats, or report breakage. Join whichever you prefer.`}
  />

  <section class="section">
    <div class="prose">
      <slot />
    </div>
  </section>

  <Disclaimer singleplayerOnly={data.singleplayer_only} />
</Base>
