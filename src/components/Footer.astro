---
import { url } from '../utils/url';
import Icon from './Icon.astro';
import { TELEGRAM, MATRIX } from '../utils/community';

const REPO = 'https://github.com/thereisnotime/tint-cheats';
const REPORT_ISSUE = `${REPO}/issues/new?template=report-issue.yml`;
const REQUEST_CHEAT = `${REPO}/issues/new?template=request-cheat.yml`;
const LICENSE = `${REPO}/blob/main/LICENSE`;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__cta">
    <div class="site-footer__cta-text">
      <h2 class="site-footer__cta-title">Join the community</h2>
      <p class="site-footer__cta-blurb">
        Update alerts, cheat requests, and help from other players.
      </p>
    </div>
    <div class="site-footer__cta-actions">
      <a class="btn community__btn community__btn--tg" href={TELEGRAM} rel="noopener">
        <Icon name="telegram" size={18} /> Telegram
      </a>
      <a class="btn community__btn community__btn--mx" href={MATRIX} rel="noopener">
        <Icon name="matrix" size={18} /> Matrix
      </a>
      <a class="btn btn--ghost" href={url('/contribute')}>
        <Icon name="users" size={18} /> Contribute a cheat
      </a>
    </div>
  </div>

  <div class="site-footer__inner">
    <p class="site-footer__pledge">
      Free and open source. No surveys, no link shorteners, no paywalls — ever.
    </p>
    <nav class="site-footer__links" aria-label="Footer">
      <a href={url('/how-to-use-cheat-engine')}>How to use</a>
      <a href={url('/contribute')}>Contribute a cheat</a>
      <a href={TELEGRAM} rel="noopener">Telegram</a>
      <a href={MATRIX} rel="noopener">Matrix</a>
      <a href={REPO} rel="noopener">GitHub</a>
      <a href={REPORT_ISSUE} rel="noopener">Report an issue</a>
      <a href={REQUEST_CHEAT} rel="noopener">Request a cheat</a>
      <a href={url('/rss.xml')}>RSS</a>
      <a href={LICENSE} rel="noopener">License</a>
    </nav>
    <p class="site-footer__fine">
      For offline, single-player use only. Do not use in online or multiplayer
      games. tint-cheats is a community project and is not affiliated with,
      endorsed by, or sponsored by any game developer or publisher. All
      trademarks belong to their respective owners.
    </p>
    <p class="site-footer__fine">© {year} tint-cheats contributors.</p>
  </div>
</footer>
