---
import { url } from '../utils/url';

const REPO = 'https://github.com/thereisnotime/tint-cheats';
const REPORT_ISSUE = `${REPO}/issues/new?template=report-issue.yml`;
const REQUEST_CHEAT = `${REPO}/issues/new?template=request-cheat.yml`;
const LICENSE = `${REPO}/blob/main/LICENSE`;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <p class="site-footer__pledge">
      Free and open source. No surveys, no link shorteners, no paywalls — ever.
    </p>
    <nav class="site-footer__links" aria-label="Footer">
      <a href={REPO} rel="noopener">GitHub</a>
      <a href={REPORT_ISSUE} rel="noopener">Report an issue</a>
      <a href={REQUEST_CHEAT} rel="noopener">Request a cheat</a>
      <a href={url('/rss.xml')}>RSS</a>
      <a href={LICENSE} rel="noopener">License</a>
    </nav>
    <p class="site-footer__fine">
      For offline, single-player use only. Do not use in online or multiplayer
      games. tint-cheats is a community project and is not affiliated with,
      endorsed by, or sponsored by any game developer or publisher. All
      trademarks belong to their respective owners.
    </p>
    <p class="site-footer__fine">© {year} tint-cheats contributors.</p>
  </div>
</footer>
