---
/**
 * Inline SVG icon set. Stroke-based, inherits `currentColor`, no dependencies.
 * Decorative by default (aria-hidden); pass `label` to expose it to AT.
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
  label?: string;
}

const { name, size = 20, class: className, label }: Props = Astro.props;

const ICONS: Record<string, string> = {
  shield: '<path d="M12 3 4 6v6c0 4 3 7 8 9 5-2 8-5 8-9V6l-8-3Z"/>',
  search: '<circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/>',
  lock: '<rect x="4.5" y="10.5" width="15" height="10" rx="2"/><path d="M8 10.5V7a4 4 0 0 1 8 0v3.5"/>',
  gamepad:
    '<rect x="2.5" y="6.5" width="19" height="11" rx="5.5"/><path d="M7 11h4M9 9v4"/><circle cx="16" cy="10.5" r=".9" fill="currentColor" stroke="none"/><circle cx="17.5" cy="13" r=".9" fill="currentColor" stroke="none"/>',
  alert:
    '<path d="M12 4 2.6 20.4h18.8L12 4Z"/><path d="M12 10v4.2"/><circle cx="12" cy="17.6" r=".4" fill="currentColor" stroke="none"/>',
  check: '<path d="m4 12 5 5L20 6"/>',
  'check-circle': '<circle cx="12" cy="12" r="9"/><path d="m8 12 2.6 2.6L16.2 9"/>',
  download: '<path d="M12 3v12"/><path d="m7 11 5 5 5-5"/><path d="M4 20h16"/>',
  star: '<path d="m12 2.6 2.7 5.8 6.3.7-4.7 4.3 1.3 6.2L12 16.8 6.1 19.6l1.3-6.2-4.7-4.3 6.3-.7L12 2.6Z" fill="currentColor" stroke="none"/>',
  crosshair:
    '<circle cx="12" cy="12" r="7.5"/><path d="M12 1.5v4M12 18.5v4M1.5 12h4M18.5 12h4"/>',
  play: '<path d="M7 4.5v15l13-7.5L7 4.5Z" fill="currentColor" stroke="none"/>',
  image:
    '<rect x="3.5" y="4.5" width="17" height="15" rx="2"/><circle cx="8.5" cy="9.5" r="1.6"/><path d="m4.5 18 5-5 4 4 3-3 3.5 3.5"/>',
  telegram: '<path d="M22 3 2 10.5l6 2.2M22 3l-3 16-7-5.5M22 3 8 12.7M8 12.7 7.7 19l4.3-5.5"/>',
  matrix:
    '<path d="M6 3H3v18h3"/><path d="M18 3h3v18h-3"/><path d="M8 16.5v-7M8 9.5c0-.8.7-1.5 1.5-1.5S11 8.7 11 9.5v7M13 16.5v-7M13 9.5c0-.8.7-1.5 1.5-1.5S16 8.7 16 9.5v7"/>',
  users:
    '<circle cx="9" cy="8" r="3.2"/><path d="M3.5 20a5.5 5.5 0 0 1 11 0"/><path d="M16 5.2a3.2 3.2 0 0 1 0 6M17.5 14.4A5.5 5.5 0 0 1 20.5 20"/>',
};

const inner = ICONS[name] ?? '';
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  role={label ? 'img' : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  set:html={inner}
></svg>
