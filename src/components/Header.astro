---
import { url } from '../utils/url';

const REPO = 'https://github.com/thereisnotime/tint-cheats';
const NEW_ISSUE = `${REPO}/issues/new/choose`;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href={url('/')}>
      <span class="brand__mark" aria-hidden="true">⌬</span>
      <span>tint-cheats</span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      <a href={url('/')}>Home</a>
      <a href={url('/#tables')}>Tables</a>
      <a href={REPO} rel="noopener">GitHub</a>
      <a class="nav-cta" href={NEW_ISSUE} rel="noopener">Report issue</a>
      <a class="nav-cta" href={NEW_ISSUE} rel="noopener">Request a cheat</a>
    </nav>
  </div>
</header>
