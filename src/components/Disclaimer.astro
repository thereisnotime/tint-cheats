---
interface Props {
  singleplayerOnly?: boolean;
}

import Icon from './Icon.astro';

const { singleplayerOnly = true }: Props = Astro.props;
---

<aside class="banner banner--warn" role="note" aria-label="Usage disclaimer">
  <Icon name="alert" class="banner__icon" size={22} />
  <div class="banner__body">
    <strong>Use responsibly.</strong>
    <ul>
      {
        singleplayerOnly && (
          <li>
            For <strong>offline / single-player use only</strong>. Do not use in
            online or multiplayer modes — doing so risks account bans.
          </li>
        )
      }
      <li>Provided for educational and personal use.</li>
      <li>Use at your own risk; no warranty of any kind.</li>
      <li>
        Not affiliated with, endorsed by, or sponsored by any game developer or
        publisher.
      </li>
    </ul>
  </div>
</aside>
