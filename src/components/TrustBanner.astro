---
import Icon from './Icon.astro';
const REPO = 'https://github.com/thereisnotime/tint-cheats';
---

<aside class="banner banner--trust" aria-label="Trust pledge">
  <Icon name="shield" class="banner__icon" size={22} />
  <p class="banner__body">
    <strong>100% free and open source.</strong> No surveys, no link shorteners,
    no paywalls. Every table&rsquo;s
    <a href={REPO} target="_blank" rel="noopener">source</a> is visible, checksummed, and
    VirusTotal-linked.
  </p>
</aside>
