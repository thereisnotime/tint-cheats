    <CheatEntry>
      <ID>1</ID>
      <Description>Fatekeeper Trainer v1.0.1  by TINT</Description>
      <Color>808080</Color>
      <GroupHeader>1</GroupHeader>
      <Options moHideChildren="0" moDeactivateChildrenAsWell="1"/>
    </CheatEntry>

    <!--
      God Mode  (code hook on the shared damage-application routine)

        AOB (unique, 1 match):  F3 0F 11 76 34 E8 ?? ?? ?? ?? 48 8B F8
        Hooked instruction:     movss [rsi+34],xmm6   (stores new health)
        Context (verified):     xmm6 = [rsi+30] - clamped_damage  (health - damage)
        rsi                  =  health-bearing character object (player AND enemies)
        rsi+34               =  current health (float)
        rsi+378              =  "has health component" flag (NOT a player/enemy
                                 discriminator; enemies have it set too)

      Logic: if [rsi+378] != 0  -> force health to 999  (player stays topped up).
             else               -> run the original store unchanged.
      Enemies keep this flag set too, so God Mode does not make them invincible in
      practice for the player's own kills; OHK is handled by a separate cheat that
      needs a real enemy discriminator (found empirically, see One-Hit-Kill entry).

      Why AOB and not a static offset:
        The original qteeq table hardcoded "SLASHER-Win64-Shipping.exe"+5E187A0.
        A game patch shifted code by 0x19A0; the same instruction now lives at
        +0x5E1A140 (current build).  aobscanmodule re-locates it every enable,
        so this table self-heals across updates instead of silently doing nothing.

      Verified this session: AOB resolves to exactly ONE address; God Mode
      confirmed working in-game (player health locked high).
    -->
    <CheatEntry>
      <ID>2</ID>
      <Description>[ F1 ]  God Mode</Description>
      <Color>00FF80</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <Hotkeys>
        <Hotkey>
          <Action>Toggle</Action>
          <Keys>112</Keys>
          <ActivateSound>Activate</ActivateSound>
          <DeactivateSound>Deactivate</DeactivateSound>
        </Hotkey>
      </Hotkeys>
      <AssemblerScript>[ENABLE]
aobscanmodule(fkHP,SLASHER-Win64-Shipping.exe,F3 0F 11 76 34 E8 ?? ?? ?? ?? 48 8B F8)
alloc(newmem,$1000,fkHP)

label(orig)
label(return)

newmem:
  cmp dword ptr [rsi+378],0
  je orig
  mov dword ptr [rsi+34],(float)999.0
  jmp return
orig:
  movss [rsi+34],xmm6
  jmp return

fkHP:
  jmp newmem
return:

registersymbol(fkHP)

[DISABLE]
fkHP:
  db F3 0F 11 76 34
  // movss [rsi+34],xmm6   (original)

unregistersymbol(fkHP)
dealloc(newmem)
</AssemblerScript>
    </CheatEntry>

    <!-- ===================== separator: footer ===================== -->
