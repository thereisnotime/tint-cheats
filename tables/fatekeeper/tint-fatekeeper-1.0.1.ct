        </Hotkey>
      </Hotkeys>
      <AssemblerScript>{$LUA}
if syntaxcheck then return end

[ENABLE]
local al = getAddressList()
for i = 0, al.Count - 1 do
  local mr = al.getMemoryRecord(i)
  pcall(function()
    if mr and not mr.isGroupHeader then mr.Active = false end
  end)
end
MainForm.Caption = "Fatekeeper Trainer v1.0.1  [ALL CHEATS OFF]"

[DISABLE]
</AssemblerScript>
    </CheatEntry>

  </CheatEntries>

  <LuaScript>
--[[ Fatekeeper Trainer v1.0.1  by TINT
     Game version: current Steam build (AOB-based, version independent)
     Process: SLASHER-Win64-Shipping.exe

     Hotkeys:
       F1  -- God Mode + One-Hit-Kill (single hook on the health-write instruction)
       F12 -- Disable All (panic key)

     Mechanisms:
       - Auto-attaches on load; polls every 2s until game runs.
       - Disables all active cheats when game process exits.
       - Title bar shows attach status and active cheat.

     God Mode + OHK hook:
       aobscanmodule on  F3 0F 11 76 34 E8 ?? ?? ?? ?? 48 8B F8
       = movss [rsi+34],xmm6   (game's health write; rsi = character object)
       rsi+34  = health (float);  rsi+378 = player(!=0)/enemy(==0) discriminator
       player -> 999 (god mode),  enemy -> 0 (one-hit-kill)
       Original qteeq offset +5E187A0 died on a patch; AOB now lands at +5E1A140.
]]

local FK_PROC = "SLASHER-Win64-Shipping.exe"
local _FK_attached = false
local _FK_pid      = 0

local function FK_disableAll()
  local al = getAddressList()
  for i = 0, al.Count - 1 do
    local mr = al.getMemoryRecord(i)
    pcall(function()
      if mr and not mr.isGroupHeader then mr.Active = false end
    end)
  end
end

local _FK_watchTimer = createTimer(nil, false)
_FK_watchTimer.Interval = 2000
_FK_watchTimer.OnTimer = function()
  local pid = getProcessIDFromProcessName(FK_PROC)
  if pid and pid ~= 0 then
    if not _FK_attached or _FK_pid ~= pid then
      if _FK_attached then FK_disableAll() end
      openProcess(pid)
      _FK_attached = true
      _FK_pid      = pid
      MainForm.Caption = "Fatekeeper Trainer v1.0.1  [ATTACHED pid=" .. pid .. "]"
    end
  else
    if _FK_attached then
      FK_disableAll()
      _FK_attached = false
      _FK_pid      = 0
      MainForm.Caption = "Fatekeeper Trainer v1.0.1  [WAITING FOR GAME...]"
    end
  end
end
_FK_watchTimer.Enabled = true

local _pid0 = getProcessIDFromProcessName(FK_PROC)
if _pid0 and _pid0 ~= 0 then
  openProcess(_pid0)
  _FK_attached = true
  _FK_pid      = _pid0
  MainForm.Caption = "Fatekeeper Trainer v1.0.1  [ATTACHED pid=" .. _pid0 .. "]"
else
  MainForm.Caption = "Fatekeeper Trainer v1.0.1  [WAITING FOR GAME...]"
end
  </LuaScript>
  <UserdefinedSymbols/>
</CheatTable>
