{
  "name": "tint-cheats",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/gen-checksums.mjs && astro build",
    "preview": "astro preview",
